<Window x:Class="HighRiskSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="HighRisk Simulator"
        Width="1440"
        Height="920"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource WindowBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TitleBrush}"/>
        </Style>

        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        </Style>

        <Style x:Key="SidebarSectionBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Background" Value="#FBFDFF"/>
        </Style>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="ToastCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Width" Value="270"/>
        </Style>

        <Style x:Key="SliderStyleCompact" TargetType="Slider">
            <Setter Property="Minimum" Value="0.25"/>
            <Setter Property="Maximum" Value="4.00"/>
            <Setter Property="TickFrequency" Value="0.25"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="Margin" Value="0,6,0,10"/>
        </Style>

        <Style x:Key="SceneDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource DisplayDataGridStyle}">
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="HighRisk Simulator · Sistema Teleférico Mukumbarí" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                    <TextBlock Text="Centro maestro de simulación, observabilidad y entrenamiento de riesgos en altura." Margin="0,4,0,8" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                    <Border Background="#EEF4FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="14" Padding="12,10">
                        <TextBlock Text="{Binding NarrativeText}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TitleBrush}"/>
                    </Border>
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Estado" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding OperationalStateText}" Margin="0,4,0,0" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Tiempo" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding ElapsedText}" Margin="0,4,0,0" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Riesgo" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding CurrentRiskText}" Margin="0,4,0,0" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ZONA PRINCIPAL: 3 columnas Auto / * / Auto -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- COL 0: PANEL OPERADOR + ESTACIONES -->
            <Grid Grid.Column="0" Margin="0,0,10,0" Width="340">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ToggleButton Grid.Row="0" IsChecked="{Binding IsOperatorPanelExpanded, Mode=TwoWay}" Cursor="Hand" Margin="0,0,0,8">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bg" Background="#0F172A" CornerRadius="14" Padding="14,10" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="☰" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Panel de operador" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Arr" Grid.Column="2" Text="▼" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Arr" Property="Text" Value="▲"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1E293B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10" MaxHeight="560"
                        Visibility="{Binding IsOperatorPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SidebarSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Configuración de sesión" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Modo" Style="{StaticResource CaptionStyle}" Margin="0,12,0,4"/>
                                    <ComboBox ItemsSource="{Binding SimulationModes}" SelectedItem="{Binding SelectedMode}" DisplayMemberPath="DisplayName"/>
                                    <TextBlock Text="Escenario" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <ComboBox ItemsSource="{Binding ScenarioOptions}" SelectedItem="{Binding SelectedScenario}" DisplayMemberPath="DisplayName" IsEnabled="{Binding IsScriptedMode}"/>
                                    <TextBlock Text="Presión operacional" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <ComboBox ItemsSource="{Binding PressureModeOptions}" SelectedItem="{Binding SelectedPressureMode}" DisplayMemberPath="DisplayName"/>
                                    <TextBlock Text="Densidad de cabinas" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <ComboBox ItemsSource="{Binding CabinDensityOptions}" SelectedItem="{Binding SelectedCabinDensity}" DisplayMemberPath="DisplayName"/>
                                    <TextBlock Text="Fecha simulada" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <DatePicker SelectedDate="{Binding SelectedSimulationDate}"/>
                                    <TextBlock Text="Semilla base" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="{Binding ScenarioDescriptionText}" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SidebarSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Aceleración de tiempo" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Preset rápido" Style="{StaticResource CaptionStyle}" Margin="0,12,0,4"/>
                                    <ComboBox ItemsSource="{Binding TimeScaleOptions}" SelectedItem="{Binding SelectedTimeScale}" DisplayMemberPath="DisplayName"/>
                                    <TextBlock Text="Control manual 1x a 50x" Style="{StaticResource CaptionStyle}" Margin="0,12,0,4"/>
                                    <Slider Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="False" Value="{Binding ManualTimeScale, Mode=TwoWay}"/>
                                    <DockPanel Margin="0,4,0,0">
                                        <TextBlock Text="Escala activa" Style="{StaticResource CaptionStyle}"/>
                                        <TextBlock Text="{Binding ManualTimeScaleText}" DockPanel.Dock="Right" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SidebarSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Panel maestro de riesgos" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Multiplicador global" Style="{StaticResource CaptionStyle}" Margin="0,12,0,0"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding GlobalRiskMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Tormentas" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding StormProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Vientos fuertes" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding WindProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Neblina" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding FogProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Desgaste mecánico" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding MechanicalWearProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Falla mecánica de cabina" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding CabinMechanicalFailureProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Cortes de energía" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding PowerOutageProbabilityMultiplier, Mode=TwoWay}"/>
                                    <TextBlock Text="Picos de tensión" Style="{StaticResource CaptionStyle}"/>
                                    <Slider Style="{StaticResource SliderStyleCompact}" Value="{Binding VoltageSpikeProbabilityMultiplier, Mode=TwoWay}"/>
                                    <Button Content="Aplicar calibración" Command="{Binding ApplyRiskTuningCommand}" Style="{StaticResource AccentButtonStyle}" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding RiskCalibrationSummaryText}" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SidebarSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Quick-Trigger" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Objetivo" Style="{StaticResource CaptionStyle}" Margin="0,10,0,4"/>
                                    <ComboBox ItemsSource="{Binding InjectionTargetOptions}" SelectedItem="{Binding SelectedInjectionTarget}" DisplayMemberPath="DisplayName"/>
                                    <UniformGrid Columns="2" Margin="0,12,0,0">
                                        <Button Content="Tormenta" Command="{Binding InjectStormCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Viento" Command="{Binding InjectStrongWindCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Neblina" Command="{Binding InjectFogCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Sobrecarga" Command="{Binding InjectOverloadCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Falla mecánica" Command="{Binding InjectMechanicalFailureCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Desgaste" Command="{Binding InjectPulleyWearCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Falla eléctrica" Command="{Binding InjectElectricalFailureCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                        <Button Content="Pico tensión" Command="{Binding InjectVoltageSpikeCommand}" Style="{StaticResource QuickActionButtonStyle}"/>
                                    </UniformGrid>
                                    <Button Content="Parada de emergencia" Command="{Binding InjectEmergencyStopCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SidebarSectionBorderStyle}">
                                <WrapPanel>
                                    <Button Content="Iniciar" Command="{Binding StartCommand}" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="Pausar" Command="{Binding PauseCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="Paso" Command="{Binding StepCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="Reiniciar" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="Simulacro completo" Command="{Binding InstantSimulationCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="Cerrar y exportar" Command="{Binding FastForwardAndExportCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="Exportar reporte" Command="{Binding ExportReportCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Telemetría de estaciones (vertical, siempre visible) -->
                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Telemetría de estaciones" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="{Binding StationTelemetrySummaryText}" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding StationStates}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Style="{StaticResource CaptionStyle}" Margin="0,2,0,8"/>
                                                <DockPanel Margin="0,0,0,6">
                                                    <TextBlock Text="Ascenso" Style="{StaticResource CaptionStyle}"/>
                                                    <TextBlock Text="{Binding WaitingAscendingPassengers}" DockPanel.Dock="Right" FontWeight="SemiBold"/>
                                                </DockPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <TextBlock Text="Descenso" Style="{StaticResource CaptionStyle}"/>
                                                    <TextBlock Text="{Binding WaitingDescendingPassengers}" DockPanel.Dock="Right" FontWeight="SemiBold"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding BoardingRulesDisplay}" Margin="0,4,0,0" Style="{StaticResource CaptionStyle}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- COL 1: SANDBOX (dominante, Width="*") -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Sandbox visual · línea y entorno dinámico" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Cabinas, estaciones, clima y estado de fallas en escena escalable mediante ViewBox proporcional." Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="12" Padding="10,6" VerticalAlignment="Top">
                                <TextBlock Text="{Binding CurrentWeatherText}" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                            </Border>
                        </Grid>
                        <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Canvas x:Name="RouteCanvas" Width="1600" Height="900" Background="#0F172A"/>
                        </Viewbox>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="14,10" Margin="0,8,0,0">
                    <UniformGrid Columns="6">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Clima" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentWeatherText}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Ocupación media" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding AverageOccupancyText}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Incidencias activas" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ActiveIncidentText}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Visibilidad" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding VisibilityText}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Engelamiento" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding IcingText}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Pasajeros procesados" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ProcessedPassengersText}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>
            </Grid>

            <!-- COL 2: FICHA + TELEMETRÍA HISTÓRICA -->
            <Grid Grid.Column="2" Margin="10,0,0,0" Width="320">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Ficha operativa" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Perfil y semillas activas para reproducibilidad académica." Margin="0,4,0,14" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Perfil del día" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentDayProfileText}" DockPanel.Dock="Right" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Temporada" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SeasonalityText}" DockPanel.Dock="Right" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Presión" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PressureModeText}" DockPanel.Dock="Right" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Fecha" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SimulationDateText}" DockPanel.Dock="Right" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Varianza operacional" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OperationalVarianceSeedText}" DockPanel.Dock="Right" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Telemetría histórica" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Riesgo, ocupación media y presión climática con ventana móvil." Margin="0,4,0,10" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ScottPlot:WpfPlot x:Name="MetricsPlot" Grid.Row="1" MinHeight="220"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14">
                    <TextBlock Text="{Binding ExportStatusText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                </Border>
            </Grid>
        </Grid>

        <!-- PESTAÑAS INFERIORES -->
        <TabControl Grid.Row="2" Margin="0,10,0,0" MaxHeight="260">
            <TabItem Header="Eventos">
                <Border Padding="12" Background="White">
                    <DataGrid ItemsSource="{Binding EventLog}" Style="{StaticResource SceneDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hora" Binding="{Binding OccurredAt, StringFormat={}{0:hh\:mm\:ss}}" Width="110"/>
                            <DataGridTextColumn Header="Severidad" Binding="{Binding SeverityDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TypeDisplay}" Width="160"/>
                            <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="220"/>
                            <DataGridTextColumn Header="Detalle" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Fuente" Binding="{Binding SourceTag}" Width="130"/>
                            <DataGridTextColumn Header="Riesgo Δ" Binding="{Binding RiskDelta, StringFormat={}{0:F1}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            <TabItem Header="Cabinas">
                <Border Padding="12" Background="White">
                    <DataGrid ItemsSource="{Binding CabinStates}" Style="{StaticResource SceneDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cabina" Binding="{Binding Code}" Width="90"/>
                            <DataGridTextColumn Header="Tramo" Binding="{Binding SegmentName}" Width="140"/>
                            <DataGridTextColumn Header="Dirección" Binding="{Binding DirectionDisplay}" Width="110"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding OperationalStateDisplay}" Width="150"/>
                            <DataGridTextColumn Header="Alerta" Binding="{Binding AlertLevelDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Ocupación" Binding="{Binding CompactOccupancyLabel}" Width="150"/>
                            <DataGridTextColumn Header="Velocidad" Binding="{Binding VelocityMetersPerSecond, StringFormat={}{0:F2} m/s}" Width="110"/>
                            <DataGridTextColumn Header="Altitud" Binding="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Width="90"/>
                            <DataGridTextColumn Header="Salud" Binding="{Binding HealthSummaryDisplay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            <TabItem Header="Estaciones">
                <Border Padding="12" Background="White">
                    <DataGrid ItemsSource="{Binding StationStates}" Style="{StaticResource SceneDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="80"/>
                            <DataGridTextColumn Header="Estación" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Altitud" Binding="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Width="90"/>
                            <DataGridTextColumn Header="Ascenso" Binding="{Binding WaitingAscendingPassengers}" Width="90"/>
                            <DataGridTextColumn Header="Descenso" Binding="{Binding WaitingDescendingPassengers}" Width="95"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalWaitingPassengers}" Width="90"/>
                            <DataGridTextColumn Header="Regla" Binding="{Binding BoardingRulesDisplay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Toasts -->
        <ItemsControl ItemsSource="{Binding ToastNotifications}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,94,10,0" Panel.ZIndex="50">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ToastCardStyle}" BorderBrush="{Binding AccentColor}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding IconGlyph}" FontSize="16" FontWeight="Bold" Foreground="{Binding AccentColor}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Message}" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
