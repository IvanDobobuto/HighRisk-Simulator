<Window x:Class="HighRiskSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="HighRisk Simulator"
        Width="1450"
        Height="930"
        MinWidth="1280"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,16"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="HighRisk Simulator"
                               FontSize="29"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}"/>
                    <TextBlock Text="Base profesional del simulador 1D inspirada en el Sistema Teleférico Mukumbarí."
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding NarrativeText}"
                               Margin="0,14,0,0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Margin="6" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Estado" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="{Binding OperationalStateText}" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Margin="6" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Tiempo simulado" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="{Binding ElapsedText}" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Margin="6" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Clima actual" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="{Binding CurrentWeatherText}" Margin="0,6,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Margin="6" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Pasajeros procesados" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="{Binding ProcessedPassengersText}" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,16"
                Padding="16">
            <WrapPanel>
                <StackPanel Width="210" Margin="0,0,14,0">
                    <TextBlock Text="Modo de simulación" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                    <ComboBox ItemsSource="{Binding SimulationModes}"
                              SelectedItem="{Binding SelectedMode}"
                              DisplayMemberPath="DisplayName"
                              Height="34"/>
                </StackPanel>

                <StackPanel Width="255" Margin="0,0,14,0">
                    <TextBlock Text="Escenario guionizado" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                    <ComboBox ItemsSource="{Binding ScenarioOptions}"
                              SelectedItem="{Binding SelectedScenario}"
                              DisplayMemberPath="DisplayName"
                              Height="34"
                              IsEnabled="{Binding IsScriptedMode}"/>
                </StackPanel>

                <StackPanel Width="150" Margin="0,0,14,0">
                    <TextBlock Text="Semilla" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                    <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged}" Height="34"/>
                </StackPanel>

                <StackPanel Width="220" Margin="0,0,14,0">
                    <TextBlock Text="Perfil operativo activo" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                    <Border Height="52"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,7,8,0" Width="229">
                        <TextBlock Text="{Binding CurrentDayProfileText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,9" Width="200"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                    <Button Content="Iniciar"
                            Command="{Binding StartCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="110"/>
                    <Button Content="Pausar"
                            Command="{Binding PauseCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="110"/>
                    <Button Content="Paso"
                            Command="{Binding StepCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="110"/>
                    <Button Content="Reiniciar"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"
                            Margin="0"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.25*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="390"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,16,16"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Perfil operativo del sistema"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock Text="Animación 1D sobre un perfil altimétrico aproximado del recorrido Mukumbarí."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Canvas x:Name="RouteCanvas"
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            Background="#0F172A"
                            ClipToBounds="True"/>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,16"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Telemetría con ScottPlot"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock Text="Riesgo, ocupación media y presión climática en tiempo real."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <ScottPlot:WpfPlot x:Name="MetricsPlot"
                                       Grid.Row="1"
                                       Margin="0,16,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,16,0"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Log de eventos"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>

                        <ListBox Grid.Row="1"
                                 Margin="0,14,0,0"
                                 ItemsSource="{Binding EventLog}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TitleBrush}"/>
                                                <Border DockPanel.Dock="Right"
                                                        Background="#E2E8F0"
                                                        Padding="8,3"
                                                        CornerRadius="10">
                                                    <TextBlock Text="{Binding Severity}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TitleBrush}"/>
                                                </Border>
                                            </DockPanel>

                                            <TextBlock Text="{Binding Description}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedTextBrush}"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding OccurredAt, StringFormat={}{0:mm\:ss}}"
                                                           FontSize="11"
                                                           Foreground="#64748B"/>
                                                <TextBlock Text="   •   " FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding SourceTag}" FontSize="11" Foreground="#64748B"/>
                                                <TextBlock Text="   •   " FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid Grid.Column="1" Margin="16,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Cabinas"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TitleBrush}"/>

                                <DataGrid Grid.Row="1"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding CabinStates}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="80"/>
                                        <DataGridTextColumn Header="Tramo" Binding="{Binding SegmentName}" Width="*"/>
                                        <DataGridTextColumn Header="Sentido" Binding="{Binding Direction}" Width="90"/>
                                        <DataGridTextColumn Header="Estado" Binding="{Binding OperationalState}" Width="115"/>
                                        <DataGridTextColumn Header="Carga" Binding="{Binding PassengerCount}" Width="70"/>
                                        <DataGridTextColumn Header="Cap." Binding="{Binding Capacity}" Width="60"/>
                                        <DataGridTextColumn Header="Vel." Binding="{Binding VelocityMetersPerSecond, StringFormat={}{0:F1}}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Estaciones"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TitleBrush}"/>

                                <DataGrid Grid.Row="1"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding StationStates}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Estación" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="Asc." Binding="{Binding WaitingAscendingPassengers}" Width="70"/>
                                        <DataGridTextColumn Header="Desc." Binding="{Binding WaitingDescendingPassengers}" Width="70"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding TotalWaitingPassengers}" Width="70"/>
                                        <DataGridTextColumn Header="Alt." Binding="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Notas de operación"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}"/>

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="{Binding ScenarioDescriptionText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"/>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="Riesgo agregado"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <ProgressBar Height="14"
                                     Margin="0,8,0,0"
                                     Maximum="100"
                                     Value="{Binding CurrentRiskValue}"/>
                        <TextBlock Text="{Binding CurrentRiskText}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,8,0" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="Ocupación media" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{Binding AverageOccupancyText}" Margin="0,6,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="8,0,0,0" Padding="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="Incidentes activos" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{Binding ActiveIncidentText}" Margin="0,6,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4" Margin="0,18,0,0" Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Leyenda visual"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TitleBrush}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Rectangle Width="16" Height="16" Fill="#22C55E" RadiusX="3" RadiusY="3"/>
                                <TextBlock Text="  Operación normal o crucero" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Rectangle Width="16" Height="16" Fill="#38BDF8" RadiusX="3" RadiusY="3"/>
                                <TextBlock Text="  Cabina detenida en estación" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Rectangle Width="16" Height="16" Fill="#F59E0B" RadiusX="3" RadiusY="3"/>
                                <TextBlock Text="  Frenado o condición de alerta" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Rectangle Width="16" Height="16" Fill="#EF4444" RadiusX="3" RadiusY="3"/>
                                <TextBlock Text="  Falla crítica o fuera de servicio" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Text="La arquitectura ya quedó lista para una futura migración a un sandbox 2D: el motor vive fuera de WPF y la UI solo consume snapshots."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
