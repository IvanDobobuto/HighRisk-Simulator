<Window x:Class="HighRiskSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="HighRisk Simulator"
        Width="1440"
        Height="920"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="#0A0F1C" TextElement.Foreground="#E2E8F0">

   

        <Window.Resources>
            <Style x:Key="GamePanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#CC0F172A"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="BorderBrush" Value="#334155"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                    <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#334155" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Margin="0,0,10,0" Padding="15,5" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#38BDF8"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#38BDF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaybackButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value> 
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="OpenLeftPanel">
            <DoubleAnimation Storyboard.TargetName="LeftPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CloseLeftPanel">
            <DoubleAnimation Storyboard.TargetName="LeftPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="-360" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="OpenRightPanel">
            <DoubleAnimation Storyboard.TargetName="RightPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CloseRightPanel">
            <DoubleAnimation Storyboard.TargetName="RightPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="380" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

        <Grid ClipToBounds="True">
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="RouteCanvas" Width="1600" Height="900" Background="#0A0F1C"/>
            </Viewbox>

        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0" Style="{StaticResource GamePanelStyle}" Padding="24,8" Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MUKUMBARÍ" FontWeight="Black" FontSize="18" Foreground="#38BDF8" VerticalAlignment="Center"/>
                <Rectangle Width="1" Height="20" Fill="#334155" Margin="20,0"/>
                <TextBlock Text="TIEMPO:" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ElapsedText}" FontSize="18" FontWeight="Bold" Width="80" VerticalAlignment="Center"/>
                <Rectangle Width="1" Height="20" Fill="#334155" Margin="10,0,20,0"/>
                <TextBlock Text="RIESGO:" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding CurrentRiskText}" FontSize="18" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center" Width="40"/>

                <Rectangle Width="1" Height="20" Fill="#334155" Margin="20,0,20,0"/>

                <Button Content="▶ INICIAR" Command="{Binding StartCommand}" Background="#16A34A" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="⏸ PAUSA" Command="{Binding PauseCommand}" Background="#CA8A04" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="⏹ RESET" Command="{Binding ResetCommand}" Background="#DC2626" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,20,0"/>
                <Button Content="🚀 SIMULACIÓN" Command="{Binding InstantSimulationCommand}" Background="Purple" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,25,0" />
                
                <Button Content="📄 REPORTE" Command="{Binding FastForwardAndExportCommand}" Background="#2563EB" Style="{StaticResource PlaybackButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="20,85,0,160">
                <ToggleButton x:Name="BtnLeftMenu" Width="48" Height="48" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="50" 
                          Background="#1E293B" Foreground="White" BorderBrush="#38BDF8" Content="⚙">
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard Storyboard="{StaticResource OpenLeftPanel}"/>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard Storyboard="{StaticResource CloseLeftPanel}"/>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

            <Border x:Name="LeftPanel" Width="340" Style="{StaticResource GamePanelStyle}" Margin="10,60,0,0" HorizontalAlignment="Left">
                    <Border.RenderTransform>
                        <TranslateTransform X="-360"/>
                    </Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <TextBlock Text="CONFIGURACIÓN DE SESIÓN" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12"/>
                            <ComboBox ItemsSource="{Binding SimulationModes}" SelectedItem="{Binding SelectedMode}" Margin="0,0,0,10"/>

                            <TextBlock Text="ACELERACIÓN DE TIEMPO" FontWeight="Bold" Foreground="#94A3B8" Margin="0,15,0,12"/>
                            <Slider Minimum="1" Maximum="50" Value="{Binding ManualTimeScale, Mode=TwoWay}"/>

                            <TextBlock Text="INYECCIÓN" FontWeight="Bold" Foreground="#94A3B8" Margin="0,20,0,12"/>
             
                        <UniformGrid Columns="2">
                            <Button Content="Tormenta" Command="{Binding InjectStormCommand}" Margin="0,0,4,4" Height="35" ToolTip="Simula tormenta eléctrica"/>
                            <Button Content="Viento" Command="{Binding InjectStrongWindCommand}" Margin="4,0,0,4" Height="35" ToolTip="Inyecta ráfagas de viento fuerte"/>
                            <Button Content="Neblina" Command="{Binding InjectFogCommand}" Margin="0,0,4,4" Height="35" ToolTip="Reduce visibilidad"/>

                            <Button Content="Falla Eléctrica." Command="{Binding InjectElectricalFailureCommand}" Margin="4,0,0,4" Height="35" Background="#B45309" Foreground="White"/>
                            <Button Content="Pico de Tensión" Command="{Binding InjectVoltageSpikeCommand}" Margin="0,0,4,4" Height="35" Background="#92400E" Foreground="White"/>
                            <Button Content="Desgaste" Command="{Binding InjectWearTearCommand}" Margin="4,0,0,4" Height="35" Background="#475569" Foreground="White" ToolTip="Acelera degradación de poleas"/>

                            <Button Content="Sobrecarga" Command="{Binding InjectOverloadCommand}" Margin="0,0,4,4" Height="35" Background="#991B1B" Foreground="White"/>
                            <Button Content="Falla Mecanica." Command="{Binding InjectMechanicalFailureCommand}" Margin="4,0,0,4" Height="35" Background="#7F1D1D" Foreground="White"/>

                            <Button Content="Emergencia" Command="{Binding InjectEmergencyStopCommand}" Margin="0,4,0,0" Height="40" Background="#DC2626" Foreground="White" FontWeight="Black" Grid.ColumnSpan="2"/>
                        </UniformGrid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,80,20,160">
                <ToggleButton x:Name="BtnRightMenu" Width="48" Height="48" VerticalAlignment="Top" HorizontalAlignment="Right" Panel.ZIndex="50" 
                          Background="#1E293B" Foreground="White" BorderBrush="#38BDF8" Content="📊">
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard Storyboard="{StaticResource OpenRightPanel}"/>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard Storyboard="{StaticResource CloseRightPanel}"/>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

            <Border x:Name="RightPanel" Width="360" Style="{StaticResource GamePanelStyle}" Margin="0,60,10,0" HorizontalAlignment="Right">
                    <Border.RenderTransform>
                        <TranslateTransform X="380"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="TELEMETRÍA EN VIVO" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10"/>

                        <ScottPlot:WpfPlot x:Name="MetricsPlot" Grid.Row="1" Background="Transparent" Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding StationStates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TotalWaitingPassengers, StringFormat={}Pax: {0}}" DockPanel.Dock="Right" Foreground="#38BDF8" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

        <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="20,0,20,15" Height="148" Panel.ZIndex="30" Style="{StaticResource GamePanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Top" Margin="5,10,20,0">
                    <TextBlock Text="TERMINAL" FontWeight="Black" FontSize="10" Foreground="#38BDF8" Opacity="0.8" Margin="0,0,0,15"/>
                    <TextBlock Text="PASAJEROS" FontWeight="Bold" FontSize="9" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding ProcessedPassengersText}" FontSize="24" FontWeight="Black" Foreground="White"/>
                    <Separator Background="#334155" Margin="0,0"/>
                    <TextBlock Text="ESTADO" FontWeight="Bold" FontSize="9" Foreground="#94A3B8"/>
                    <TextBlock Text="OPERATIVO" Foreground="#22C55E" FontWeight="Bold" FontSize="12"/>
                </StackPanel>

                <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0">

                    <TabItem Header="Eventos" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding EventLog}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Severidad"  Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding SeverityBrush}" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding SeverityDisplay}" FontSize="10" FontWeight="Bold" Foreground="Black"   HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="120"/>
                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Fuente" Binding="{Binding Source}" Width="140"/>
                                <DataGridTextColumn Header="Δ Riesgo" Binding="{Binding RiskDelta, StringFormat={}{0:F2}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Cabinas" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding CabinStates}" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Code}" Width="60" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Posición" Binding="{Binding SegmentName, StringFormat={}{0:N0} m}" Width="110"/>
                                <DataGridTemplateColumn Header="Ocupación"  Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding CompactOccupancyLabel, StringFormat={}{0}%}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Velocidad" Binding="{Binding VelocityMetersPerSecond, StringFormat={}{0:F1} m/s}" Width="100"/>
                                <DataGridTextColumn Header="Estado operativo" Binding="{Binding OperationalStateDisplay}" Width="*"/>
                                <DataGridTextColumn Header="Salud" Binding="{Binding HealthSummaryDisplay}" Width="*"/>
                                <DataGridTextColumn Header="Alerta" Binding="{Binding AlertLevelDisplay}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Estaciones" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding StationStates}" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Estación" Binding="{Binding Name}" Width="180" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Pax en espera" Binding="{Binding TotalWaitingPassengers}" Width="120" Foreground="Black"/>
                                <DataGridTextColumn Header="Altitud" Binding="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Width="90"/>
                                <DataGridTextColumn Header="Ascenso" Binding="{Binding WaitingAscendingPassengers}" Width="90"/>
                                <DataGridTextColumn Header="Descenso" Binding="{Binding WaitingDescendingPassengers}" Width="95"/>
                                <DataGridTextColumn Header="Regla" Binding="{Binding BoardingRulesDisplay}" Width="*"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

    </Grid>
    </Window>