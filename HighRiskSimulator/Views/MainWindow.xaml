<Window x:Class="HighRiskSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="HighRisk Simulator"
        Width="1440"
        Height="920"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="#0A0F1C" TextElement.Foreground="#E2E8F0">

   

        <Window.Resources>
            <Style x:Key="GamePanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#CC0F172A"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="BorderBrush" Value="#334155"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16"/>
            </Style>
            
        

        
        <SolidColorBrush x:Key="TitleBrush" Color="White"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>
        <!-- Gris azulado suave -->

        <!-- Estilo de la Tarjeta Toast (Modernizado) -->
        <Style x:Key="ToastCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E60F172A"/>
            <!-- Fondo oscuro semi-transparente -->
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <!-- Acento lateral grueso -->
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="Effect">
                <Setter.Value>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                    </Setter.Value>
            </Setter>
        </Style>


        <!-- 1. Encabezados de Columna (Grises azulados, minimalistas) -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <!-- Línea sutil debajo del título -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- 2. Celdas Individuales (Transparentes, forzando el color de texto a blanco/gris claro) -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <!-- Este Foreground es crucial para DataGridTextColumn -->
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3. Filas completas (Fondo transparente, hover neón) -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A38BDF8"/>
                    <!-- Azul neón al 10% opacidad -->
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3338BDF8"/>
                    <!-- Azul neón al 20% opacidad -->
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 4. Contenedor Principal DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>

        <!-- 5. Forzar color en todos los TextBlocks dentro del DataGrid (La bala de plata) -->
        <Style TargetType="TextBlock" x:Key="DataGridTextBlockStyle">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                    <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#334155" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Margin="0,0,10,0" Padding="15,5" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#38BDF8"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#38BDF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaybackButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value> 
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="20,10" BorderBrush="#60A5FA" BorderThickness="1.4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button" BasedOn="{StaticResource PlaybackButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Storyboard x:Key="OpenLeftPanel">
            <DoubleAnimation Storyboard.TargetName="LeftPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CloseLeftPanel">
            <DoubleAnimation Storyboard.TargetName="LeftPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="-500" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Animaciones para el Panel de Probabilidades -->
        <Storyboard x:Key="OpenProbabilityPanel">
            <DoubleAnimation Storyboard.TargetName="ProbabilityPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CloseProbabilityPanel">
            <DoubleAnimation Storyboard.TargetName="ProbabilityPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="-500" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="OpenRightPanel">
            <DoubleAnimation Storyboard.TargetName="RightPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CloseRightPanel">
            <DoubleAnimation Storyboard.TargetName="RightPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             To="500" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

        <Grid x:Name="RootLayout" ClipToBounds="True">
            <Viewbox x:Name="SceneViewbox" Stretch="Uniform" Margin="0,0,0,220">
                <Canvas x:Name="RouteCanvas" Width="1600" Height="900" Background="#0A0F1C"/>
            </Viewbox>

        <Border x:Name="TopControlBar" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0" Style="{StaticResource GamePanelStyle}" Padding="24,8" Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MUKUMBARÍ" FontWeight="Black" FontSize="18" Foreground="#38BDF8" VerticalAlignment="Center"/>
                <Rectangle Width="1" Height="20" Fill="#334155" Margin="20,0"/>
                <TextBlock Text="TIEMPO:" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ElapsedText}" FontSize="18" FontWeight="Bold" Width="80" VerticalAlignment="Center"/>
                <Rectangle Width="1" Height="20" Fill="#334155" Margin="10,0,20,0"/>
                <TextBlock Text="RIESGO:" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding CurrentRiskText}" FontSize="18" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center" Width="40"/>

                <Rectangle Width="1" Height="20" Fill="#334155" Margin="20,0,20,0"/>

                <Button Content="▶ INICIAR" Command="{Binding StartCommand}" Background="#16A34A" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="⏸ PAUSA" Command="{Binding PauseCommand}" Background="#CA8A04" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="⏹ RESET" Command="{Binding ResetCommand}" Background="#DC2626" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,20,0"/>
                <Button Content="🚀 SIMULACIÓN" Command="{Binding InstantSimulationCommand}" Background="Purple" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,25,0" />
                
                <Button Content="📄 REPORTE" Click="OpenReportDialog_Click" Background="#2563EB" Style="{StaticResource PlaybackButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="↩ SALIR" Click="ExitToMenuButton_Click" Background="#0F766E" Style="{StaticResource PlaybackButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- CAPA 2: PANELES LATERALES IZQUIERDOS (Z-Index: 50) -->
        <Grid HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="20,80,0,50" Panel.ZIndex="50">

            <!-- BARRA DE HERRAMIENTAS LATERAL -->
            <StackPanel Width="48" HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="60">
                <!-- Botón Inyección -->
                <ToggleButton x:Name="TriggerMenuToggleButton" Checked="TriggerMenuToggleButton_Checked" Width="48" Height="48" Background="#1E293B" Foreground="White" BorderBrush="#38BDF8" Content="⚡" ToolTip="Inyección rápida de eventos">
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard Storyboard="{StaticResource OpenLeftPanel}"/>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard Storyboard="{StaticResource CloseLeftPanel}"/>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

                <!-- Botón Probabilidades -->
                <ToggleButton x:Name="RiskMenuToggleButton" Checked="RiskMenuToggleButton_Checked" Width="48" Height="48" Margin="0,10,0,0" Background="#1E293B" Foreground="White" BorderBrush="#8B5CF6" Content="🎲" ToolTip="Configuración de riesgos">
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard Storyboard="{StaticResource OpenProbabilityPanel}"/>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard Storyboard="{StaticResource CloseProbabilityPanel}"/>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>
            </StackPanel>

            <!-- PANEL 1: INYECCIÓN DE RIESGOS  -->
            <Border x:Name="LeftPanel" Width="340" Style="{StaticResource GamePanelStyle}" Margin="60,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" MaxHeight="720">
                <Border.RenderTransform>
                    <TranslateTransform X="-450"/>
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel x:Name="SessionConfigurationSection">
                            <TextBlock Text="CONFIGURACIÓN DE SESIÓN" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,12"/>
                        <ComboBox ItemsSource="{Binding SimulationModes}" SelectedItem="{Binding SelectedMode}" Margin="0,0,0,10"/>

                        <TextBlock Text="SEMILLA ALEATORIA" FontWeight="Bold" Foreground="#64748B" FontSize="10"/>
                        <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,12" Padding="8,5" Background="#E5E7EB" Foreground="#0F172A" BorderThickness="0"/>

                        <TextBlock Text="FECHA DE SIMULACIÓN" FontWeight="Bold" Foreground="#64748B" FontSize="10"/>
                        <DatePicker SelectedDate="{Binding SelectedSimulationDate}" Margin="0,5,0,12"/>

                        <TextBlock Text="ACELERACIÓN DE TIEMPO" FontWeight="Bold" Foreground="#64748B" FontSize="10"/>
                        <Grid Margin="0,5,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="54"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="False" Value="{Binding ManualTimeScale, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ManualTimeScaleText}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="DURACIÓN DE JORNADA" FontWeight="Bold" Foreground="#64748B" FontSize="10"/>
                        <Grid Margin="0,5,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="54"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="10" Maximum="16" TickFrequency="0.5" IsSnapToTickEnabled="True" Value="{Binding ServiceDurationHours, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ServiceDurationHoursText}" FontWeight="Bold" Foreground="#38BDF8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- FLUJO DE PASAJEROS -->
                        <TextBlock Text="VOLUMEN DE PASAJEROS" FontWeight="Bold" Foreground="#64748B" FontSize="10"/>
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="54"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0.25" Maximum="3" Value="{Binding PassengerArrivalMultiplier, Mode=TwoWay}" TickFrequency="0.05" IsSnapToTickEnabled="False" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding PassengerArrivalMultiplierText}" FontSize="11" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#334155" Margin="0,5,0,15"/>
                        </StackPanel>

                        <StackPanel x:Name="InjectionSection" Margin="0,0,0,4">
                            <TextBlock Text="INYECCIÓN" FontWeight="Bold" Foreground="#94A3B8" Margin="0,20,0,12"/>

                        <UniformGrid Columns="2">
                            <Button Content="Tormenta" Command="{Binding InjectStormCommand}" Margin="0,0,4,4" Height="35" ToolTip="Simula tormenta eléctrica"/>
                            <Button Content="Viento" Command="{Binding InjectStrongWindCommand}" Margin="4,0,0,4" Height="35" ToolTip="Inyecta ráfagas de viento fuerte"/>
                            <Button Content="Neblina" Command="{Binding InjectFogCommand}" Margin="0,0,4,4" Height="35" ToolTip="Reduce visibilidad"/>
                            <Button Content="Nevada" Command="{Binding InjectSnowCommand}" Margin="4,0,0,4" Height="35" ToolTip="Inyecta nevada fuerte"/>

                            <Button Content="Falla eléctrica" Command="{Binding InjectElectricalFailureCommand}" Margin="4,0,0,4" Height="35" Background="#B45309" Foreground="White"/>
                            <Button Content="Pico de Tensión" Command="{Binding InjectVoltageSpikeCommand}" Margin="0,0,4,4" Height="35" Background="#92400E" Foreground="White"/>
                            <Button Content="Desgaste" Command="{Binding InjectPulleyWearCommand}" Margin="4,0,0,4" Height="35" Background="#475569" Foreground="White" ToolTip="Acelera degradación de poleas"/>

                            <Button Content="Sobrecarga" Command="{Binding InjectOverloadCommand}" Margin="0,0,4,4" Height="35" Background="#991B1B" Foreground="White"/>
                            <Button Content="Falla mecánica" Command="{Binding InjectMechanicalFailureCommand}" Margin="4,0,0,4" Height="35" Background="#7F1D1D" Foreground="White"/>

                            <Button Content="Emergencia" Command="{Binding InjectEmergencyStopCommand}" Margin="0,0,4,4" Height="35" Background="#DC2626" Foreground="White" FontWeight="Black"/>
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- PANEL 2: MOTOR DE PROBABILIDADES (NUEVO) -->
            <Border x:Name="ProbabilityPanel" Width="340" Style="{StaticResource GamePanelStyle}" Margin="60,60,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" MaxHeight="560">
                <Border.RenderTransform>
                    <TranslateTransform X="-450"/>
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="CONFIGURACIÓN DE RIESGOS" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,15"/>

                        <!-- RIESGO GLOBAL -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,20" BorderBrush="#8B5CF6" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="MULTIPLICADOR GLOBAL DE RIESGO" FontWeight="Bold" Foreground="#A78BFA" FontSize="10"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Minimum="0" Maximum="5" Value="{Binding GlobalRiskMultiplier}" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GlobalRiskMultiplier, StringFormat={}{0:F1}x}" FontWeight="Black" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- PROBABILIDADES AMBIENTALES -->
                        <TextBlock Text="VARIABLES AMBIENTALES" FontWeight="Bold" Foreground="#64748B" FontSize="10" Margin="0,0,0,10"/>

                        <TextBlock Text="Tormenta" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding StormProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding StormProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#38BDF8" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Ráfagas de Viento" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding WindProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding WindProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#38BDF8" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Neblina Densa" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding FogProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding FogProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#38BDF8" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- PROBABILIDADES TÉCNICAS -->
                        <TextBlock Text="VARIABLES DE SISTEMA" FontWeight="Bold" Foreground="#64748B" FontSize="10" Margin="0,0,0,10"/>

                        <TextBlock Text="Fallas Eléctricas" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding PowerOutageProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding PowerOutageProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#F59E0B" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Picos de tensión" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding VoltageSpikeProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding VoltageSpikeProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#F59E0B" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Fallas Mecánicas" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding CabinMechanicalFailureProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding CabinMechanicalFailureProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#DC2626" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Desgaste" FontSize="11" Foreground="#CBD5E1"/>
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="100" Value="{Binding MechanicalWearProbabilityMultiplier}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding MechanicalWearProbabilityMultiplier, StringFormat={}{0:N0}%}" Foreground="#DC2626" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,80,20,250" Panel.ZIndex="55">
                <ToggleButton x:Name="TelemetryMenuToggleButton" Width="48" Height="48" VerticalAlignment="Top" HorizontalAlignment="Right" Panel.ZIndex="50" 
                          Background="#1E293B" Foreground="White" BorderBrush="#38BDF8" Content="📊" ToolTip="Telemetría en vivo">
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard Storyboard="{StaticResource OpenRightPanel}"/>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard Storyboard="{StaticResource CloseRightPanel}"/>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

            <Border x:Name="RightPanel" Width="360" Style="{StaticResource GamePanelStyle}" Margin="0,60,10,0" HorizontalAlignment="Right">
                    <Border.RenderTransform>
                        <TranslateTransform X="380"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="TELEMETRÍA EN VIVO" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10"/>

                        <ScottPlot:WpfPlot x:Name="MetricsPlot" Grid.Row="1" Background="Transparent" Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding StationStates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TotalWaitingPassengers, StringFormat={}Pax: {0}}" DockPanel.Dock="Right" Foreground="#38BDF8" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

        <Border x:Name="BottomTerminalPanel" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="20,0,20,20" Height="220" Panel.ZIndex="30" Style="{StaticResource GamePanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Top" Margin="5,14,20,0">
                    <TextBlock Text="TERMINAL" FontWeight="Black" FontSize="10" Foreground="#38BDF8" Opacity="0.8" Margin="0,0,0,15"/>
                    <TextBlock Text="PASAJEROS" FontWeight="Bold" FontSize="9" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding ProcessedPassengersText}" FontSize="24" FontWeight="Black" Foreground="White"/>
                    <Separator Background="#334155" Margin="0,0"/>
                    <TextBlock Text="ESTADO" FontWeight="Bold" FontSize="9" Foreground="#94A3B8"/>
                    <TextBlock Text="OPERATIVO" Foreground="#22C55E" FontWeight="Bold" FontSize="12"/>
                </StackPanel>

                <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0">

                    <TabItem Header="Eventos" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding EventLog}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Severidad"  Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding SeverityBrush}" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding SeverityDisplay}" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"   HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="120" />
                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Fuente" Binding="{Binding Source}" Width="140"/>
                                <DataGridTextColumn Header="Δ Riesgo" Binding="{Binding RiskDelta, StringFormat={}{0:F2}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Cabinas" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding CabinStates}" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Code}" Width="70" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Posición" Binding="{Binding SegmentName, StringFormat={}{0:N0} m}" Width="110"/>
                                <DataGridTemplateColumn Header="Ocupación"  Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding CompactOccupancyLabel, StringFormat={}{0}%}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" FontWeight="Bold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Velocidad" Binding="{Binding VelocityMetersPerSecond, StringFormat={}{0:F1} m/s}" Width="100"/>
                                <DataGridTextColumn Header="Estado operativo" Binding="{Binding OperationalStateDisplay}" Width="*"/>
                                <DataGridTextColumn Header="Salud" Binding="{Binding HealthSummaryDisplay}" Width="*"/>
                                <DataGridTextColumn Header="Alerta" Binding="{Binding AlertLevelDisplay}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Estaciones" Style="{StaticResource LogTabItemStyle}">
                        <DataGrid ItemsSource="{Binding StationStates}" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Estación" Binding="{Binding Name}" Width="180" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Pax en espera" Binding="{Binding TotalWaitingPassengers}" Width="120" Foreground="#E2E8F0"/>
                                <DataGridTextColumn Header="Altitud" Binding="{Binding AltitudeMeters, StringFormat={}{0:F0} m}" Width="90"/>
                                <DataGridTextColumn Header="Ascenso" Binding="{Binding WaitingAscendingPassengers}" Width="90"/>
                                <DataGridTextColumn Header="Descenso" Binding="{Binding WaitingDescendingPassengers}" Width="95"/>
                                <DataGridTextColumn Header="Regla" Binding="{Binding BoardingRulesDisplay}" Width="*"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <ItemsControl ItemsSource="{Binding ToastNotifications}" 
              Grid.Row="0" Grid.RowSpan="3" 
              HorizontalAlignment="Right" VerticalAlignment="Top" 
              Margin="0,94,10,0" MaxHeight="700" 
              ClipToBounds="True" Panel.ZIndex="100">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Border con el acento dinámico (AccentColor) -->
                    <Border x:Name="ToastBorder" 
                    Style="{StaticResource ToastCardStyle}" 
                    BorderBrush="{Binding AccentColor}">

                        <StackPanel>
                            <DockPanel>
                                <!-- Icono con el color del acento -->
                                <TextBlock Text="{Binding IconGlyph}" 
                                   FontSize="16" FontWeight="Bold" 
                                   Foreground="{Binding AccentColor}" 
                                   Margin="0,0,10,0"/>

                                <TextBlock Text="{Binding Title}" 
                                   FontWeight="Black" FontSize="11"
                                   Foreground="{StaticResource TitleBrush}" 
                                   VerticalAlignment="Center"/>
                            </DockPanel>

                            <TextBlock Text="{Binding Message}" 
                               Margin="0,6,0,0" 
                               TextWrapping="Wrap" 
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}" 
                               Opacity="0.9"/>
                        </StackPanel>

                        <!-- Animación de "Slide and Fade" al cargar -->
                        <Border.RenderTransform>
                            <TranslateTransform X="350"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid x:Name="ReportDialogOverlay" Visibility="Collapsed" Background="#AA020617" Panel.ZIndex="220">
            <Border Width="430" Background="#F00F172A" BorderBrush="#38BDF8" BorderThickness="1.5" CornerRadius="18" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Generar reporte" FontSize="28" FontWeight="Black" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="Selecciona si deseas exportar solo el día actual o un lote entre fechas. Al terminar, el sistema abrirá la carpeta del archivo." TextWrapping="Wrap" Foreground="#CBD5E1" Margin="0,0,0,18"/>

                    <RadioButton x:Name="SingleDayReportOption" Content="Simulación de un día" IsChecked="True" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                    <DatePicker x:Name="ReportStartDatePicker" Margin="0,0,0,16"/>

                    <RadioButton x:Name="DateRangeReportOption" Content="Simulación por lote de días" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                    <DatePicker x:Name="ReportEndDatePicker" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Click="CloseReportDialog_Click" Background="#475569" Style="{StaticResource DialogButtonStyle}" Margin="0,0,10,0"/>
                        <Button x:Name="GenerateReportButton" Content="Generar" Click="GenerateReportFromDialog_Click" Background="#2563EB" Style="{StaticResource DialogButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="TutorialOverlay" Visibility="Collapsed" Background="#B0020617" Panel.ZIndex="250">
            <Canvas x:Name="TutorialCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Border x:Name="TutorialHighlight" Width="300" Height="120" BorderBrush="#38BDF8" BorderThickness="4" CornerRadius="18" Background="#1A38BDF8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#38BDF8" Opacity="0.85"/>
                    </Border.Effect>
                </Border>

                <Border x:Name="TutorialCard" Width="430" Background="#F00F172A" BorderBrush="#38BDF8" BorderThickness="1.5" CornerRadius="18" Padding="22">
                    <StackPanel>
                        <TextBlock x:Name="TutorialStepText" Text="Paso 1" Foreground="#38BDF8" FontWeight="Black" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TutorialTitleText" Text="Tutorial" Foreground="White" FontWeight="Black" FontSize="27" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TutorialBodyText" TextWrapping="Wrap" Foreground="#CBD5E1" FontSize="15" LineHeight="21" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="PreviousTutorialButton" Content="Anterior" Click="PreviousTutorialStep_Click" Background="#475569" Style="{StaticResource DialogButtonStyle}" Margin="0,0,8,0"/>
                            <Button x:Name="NextTutorialButton" Content="Siguiente" Click="NextTutorialStep_Click" Background="#2563EB" Style="{StaticResource DialogButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="Cerrar" Click="EndTutorial_Click" Background="#991B1B" Style="{StaticResource DialogButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Canvas>
        </Grid>

        <Grid x:Name="MainMenuOverlay" Panel.ZIndex="300">
            <Grid.Background>
                <ImageBrush ImageSource="/assets/backgrounds/background_2.png" Stretch="UniformToFill"/>
            </Grid.Background>
            <Rectangle Fill="#B0020617"/>
            <Border Width="560" Background="#E60F172A" BorderBrush="#38BDF8" BorderThickness="1.5" CornerRadius="28" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="/assets/title/title_main_menu.png" Width="460" Height="250" Stretch="Uniform" Margin="0,-25,0,-10"/>
                    <TextBlock Text="Teleférico Mukumbarí - Mérida, Venezuela" TextAlignment="Center" Foreground="#CBD5E1" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,22"/>
                    <Button Content="Tutorial" Click="StartTutorial_Click" Background="#0F766E" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Simulador" Click="StartSimulator_Click" Background="#2563EB" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Salir" Click="ExitApplication_Click" Background="#991B1B" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>


    </Grid>
    </Window>